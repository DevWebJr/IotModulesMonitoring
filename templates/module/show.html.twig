<!DOCTYPE html>

<title>Module</title>

{% block body %}
    <h1>Module</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ module.id }}</td>
            </tr>
            <tr>
                <th>IpAddress</th>
                <td>{{ module.ipAddress }}</td>
            </tr>
            <tr>
                <th>Alight</th>
                <td>{{ module.alight ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Functional</th>
                <td>{{ module.functional ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_module_index') }}">back to list</a>

    <a href="{{ path('app_module_edit', {'id': module.id}) }}">edit</a>

    {{ include('module/_delete_form.html.twig') }}
{% endblock %}
